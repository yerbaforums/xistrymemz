{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "jsx": "react-jsx",
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "baseUrl": "../src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["**/*.test.ts", "**/*.test.tsx", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
